# Copy this file to .env and fill in your PayHere SANDBOX credentials.
# Get these from https://sandbox.payhere.lk -> your merchant account -> Integrations.

PAYHERE_MERCHANT_ID=your_sandbox_merchant_id
PAYHERE_MERCHANT_SECRET=your_sandbox_merchant_secret

# The ngrok HTTPS URL that tunnels to this server (see README.md).
# Must NOT have a trailing slash. Update this every time ngrok gives you a
# new URL (free ngrok URLs change on every restart).
PUBLIC_BASE_URL=https://your-ngrok-subdomain.ngrok-free.app

PORT=4000
