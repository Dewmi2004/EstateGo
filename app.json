{
  "expo": {
    "name": "EstateGo",
    "slug": "estategoNumbergo",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#0B1F3A"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B1F3A"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "EstateGo needs access to your photos so you can add images to your property listing.",
          "cameraPermission": "EstateGo needs access to your camera so you can take photos of your property."
        }
      ]
    ]
  }
}
